{
  "appId": "com.courspool.app",
  "appName": "CoursPool",
  "webDir": "www",
  "server": {
    "url": "https://courspool.vercel.app",
    "cleartext": false,
    "allowNavigation": [
      "js.stripe.com",
      "hooks.stripe.com",
      "devoted-achievement-production-fdfa.up.railway.app",
      "*.daily.co"
    ]
  },
  "ios": {
    "allowsInlineMediaPlayback": true,
    "mediaTypesRequiringUserActionForPlayback": []
  },
  "plugins": {
    "Keyboard": {
      "resize": "body",
      "style": "dark",
      "resizeOnFullScreen": true
    },
    "StatusBar": {
      "overlaysWebView": true,
      "style": "DARK",
      "backgroundColor": "#00000000"
    }
  }
}
